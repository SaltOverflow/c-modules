module constvolatile;

int perform() {
    update_sensor(&sensor, 42);
    int result = clamp(sensor, &MAX);
    if (status != 1) return 1;
    return 0;
}

const int MAX = 100;
volatile int sensor = 0;
const volatile int status = 1;

void update_sensor(volatile int *s, int val) {
    *s = val;
}

int clamp(int val, const int *limit) {
    return val > *limit ? *limit : val;
}
